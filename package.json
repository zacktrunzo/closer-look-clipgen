{
  "name": "closer-look-clipgen",
  "version": "1.0.3",
  "description": "Automated Long-form to Short-form clip generator for the Closer Look podcast",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"cross-env NODE_ENV=development electron .\" ",
    "build:mac": "electron-builder --mac --publish always",
    "build:win": "electron-builder --win --publish always",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.closerlook.clipgen",
    "productName": "Closer Look ClipGen",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.png"
    },
    "win": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "AudioVideo"
    },
    "publish": {
      "provider": "github",
      "owner": "zacktrunzo",
      "repo": "closer-look-clipgen"
    },
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets/Branded Backgrounds/",
        "to": "assets/Branded Backgrounds",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@xenova/transformers": "^2.17.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "@helios-project/renderer": "^1.78.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1"
  }
}
